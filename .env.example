# ─── App ────────────────────────────────────────────────────────────────────
# Your full public URL (no trailing slash). Used for OAuth redirect URIs and
# as the Trello webhook callback base URL.
APP_URL=https://your-app.railway.app

# Password to protect the /setup page (choose something strong)
SETUP_PASSWORD=your-setup-password-here

# ─── Google – Source Account (downloads FROM this Drive) ────────────────────
# OAuth 2.0 Desktop client credentials from Google Cloud Console
GOOGLE_SOURCE_CLIENT_ID=
GOOGLE_SOURCE_CLIENT_SECRET=
# Optional: pre-fill refresh token (avoids needing Railway volume for token storage)
GOOGLE_SOURCE_REFRESH_TOKEN=

# ─── Google – Destination Account (uploads TO this Drive) ───────────────────
GOOGLE_DEST_CLIENT_ID=
GOOGLE_DEST_CLIENT_SECRET=
# Optional: pre-fill refresh token
GOOGLE_DEST_REFRESH_TOKEN=

# ─── Trello (server-side; no UI auth) ───────────────────────────────────────
TRELLO_KEY=
TRELLO_TOKEN=

# ─── Phase 2: Frame.io Automation ───────────────────────────────────────────
# OAuth 2.0 credentials from Adobe Developer Console
# (Create project → Add API → Frame.io → OAuth Web App)
FRAMEIO_CLIENT_ID=
FRAMEIO_CLIENT_SECRET=

# Optional: pre-fill tokens (avoids re-authorizing after restart; auto-populated
# after you click "Connect Frame.io" in the dashboard)
FRAMEIO_ACCESS_TOKEN=
FRAMEIO_REFRESH_TOKEN=

# Your Frame.io account/workspace ID (UUID)
# Find it by calling: GET https://api.frame.io/v4/accounts  (after connecting)
FRAMEIO_ACCOUNT_ID=

# Exact name of the Frame.io project where uploaded videos will land
FRAMEIO_PROJECT_NAME=Client Reviews

# Optional explicit target folder UUID for uploads (must be a folder ID, not project ID)
# If set, it takes priority over FRAMEIO_PROJECT_NAME
FRAMEIO_FOLDER_ID=

# ─── Phase 2: Trello Board Config ───────────────────────────────────────────
# Board ID of the EDITORS board (from Trello URL: trello.com/b/BOARD_ID/...)
EDITORS_TRELLO_BOARD_ID=

# Board ID of the CLIENT board
CLIENT_TRELLO_BOARD_ID=

# Exact name of the "Done" column on the editors board (case-sensitive)
DONE_LIST_NAME=Done

# Exact name of the "Double Check" column on the editors board (case-sensitive)
DOUBLE_CHECK_LIST_NAME=Double Check
